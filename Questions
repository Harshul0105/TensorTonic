Question 4: Binning

def binning(values, num_bins):
    if not values:
        return []

    mn = min(values)
    mx = max(values)

    if mn == mx:
        return [0] * len(values)

    width = (mx - mn) / num_bins
    result = []

    for v in values:
        idx = int((v - mn) / width)

        if idx == num_bins:
            idx -= 1

        result.append(idx)

    return result

